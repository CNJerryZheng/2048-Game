{
    "C_Cpp.default.compilerPath": "${env:MINGW_HOME}/bin/gcc.exe",
    "C_Cpp.default.cStandard": "c99",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/Inc"
    ],
    "cmake.cmakePath": "${env:CMAKE_HOME}/bin/cmake.exe",
    "cmake.generator": "Ninja",
    "cmake.additionalCompilerSearchDirs": [
        "${env:MINGW_HOME}/bin"
    ],
    "cmake.configureSettings": {
        "CMAKE_C_COMPILER": "${env:MINGW_HOME}/bin/gcc.exe",
        "CMAKE_MAKE_PROGRAM": "${env:NINJA_HOME}/ninja.exe"
    }
}
